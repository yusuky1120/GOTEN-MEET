{
  "name": "goten-meet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:app": "node scripts/dev-app.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check:proximity": "npx tsx scripts/check-proximity-volume.ts",
    "check:clothing": "npx tsx scripts/check-clothing-variant.ts",
    "check:presence": "npx tsx scripts/check-player-presence.ts",
    "check:connection-errors": "npx tsx scripts/check-connection-errors.ts",
    "check:remote-presence-policy": "npx tsx scripts/check-remote-presence-policy.ts",
    "check:house-chat": "npx tsx scripts/check-house-chat.ts",
    "check:room-mapping": "npx tsx scripts/check-room-mapping.ts",
    "check:avatar-types": "npx tsx scripts/check-avatar-types.ts",
    "check:onboarding-session": "npx tsx scripts/check-onboarding-session.ts",
    "check": "npm run check:proximity && npm run check:clothing && npm run check:presence && npm run check:connection-errors && npm run check:remote-presence-policy && npm run check:house-chat && npm run check:room-mapping && npm run check:avatar-types && npm run check:onboarding-session"
  },
  "dependencies": {
    "livekit-client": "^2.20.2",
    "phaser": "^3.90.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
